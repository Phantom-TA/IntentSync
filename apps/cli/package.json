{
  "name": "intentsync",
  "version": "0.1.4",
  "type": "module",
  "bin": {
    "intentsync": "./dist/index.js"
  },
  "files": [
    "dist",
    "postinstall.js"
  ],
  "scripts": {
    "dev": "tsx --tsconfig ../../tsconfig.dev.json src/index.ts",
    "build": "node build.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "postinstall": "node postinstall.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@octokit/rest": "^20.1.1",
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0",
    "bullmq": "^5.8.5",
    "chalk": "^5.3.0",
    "chromadb": "^1.9.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ioredis": "5.10.1",
    "neo4j-driver": "^5.20.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "simple-git": "^3.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@intentsync/ai-engine": "workspace:*",
    "@intentsync/analysis": "workspace:*",
    "@intentsync/core": "workspace:*",
    "@intentsync/db": "workspace:*",
    "@intentsync/embeddings": "workspace:*",
    "@intentsync/github-sync": "workspace:*",
    "@intentsync/graph": "workspace:*",
    "@intentsync/ingestion": "workspace:*",
    "@intentsync/logger": "workspace:*",
    "@intentsync/queue": "workspace:*",
    "@intentsync/repository-provider": "workspace:*",
    "@intentsync/retrieval": "workspace:*",
    "@types/node": "^20.12.11",
    "esbuild": "^0.25.0",
    "tsx": "^4.11.0"
  }
}
